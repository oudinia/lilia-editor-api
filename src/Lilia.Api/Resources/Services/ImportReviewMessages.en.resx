<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" minOccurs="0" msdata:Ordinal="1" />
                <xsd:element name="comment" minOccurs="0" msdata:Ordinal="2" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" msdata:Ordinal="0" />
              <xsd:attribute name="xml:space" type="xsd:string" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <data name="AutoTocWarning" xml:space="preserve">
    <value>Auto-inserted TOC — approve to include, reject to skip.</value>
  </data>
  <data name="TocEntryWarning" xml:space="preserve">
    <value>Likely a TOC entry imported as a heading — auto-rejected. Approve if this is a real section heading.</value>
  </data>
  <data name="ChapterLabelWarning" xml:space="preserve">
    <value>Chapter label — the chapter title follows as the next heading.</value>
  </data>
</root>
