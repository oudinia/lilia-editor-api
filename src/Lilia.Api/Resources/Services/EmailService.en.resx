<?xml version="1.0" encoding="utf-8"?>
<root>
  <xsd:schema id="root" xmlns="" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:msdata="urn:schemas-microsoft-com:xml-msdata">
    <xsd:element name="root" msdata:IsDataSet="true">
      <xsd:complexType>
        <xsd:choice maxOccurs="unbounded">
          <xsd:element name="data">
            <xsd:complexType>
              <xsd:sequence>
                <xsd:element name="value" minOccurs="0" msdata:Ordinal="1" />
                <xsd:element name="comment" minOccurs="0" msdata:Ordinal="2" />
              </xsd:sequence>
              <xsd:attribute name="name" type="xsd:string" msdata:Ordinal="0" />
              <xsd:attribute name="xml:space" type="xsd:string" />
            </xsd:complexType>
          </xsd:element>
        </xsd:choice>
      </xsd:complexType>
    </xsd:element>
  </xsd:schema>
  <data name="InviteSubject" xml:space="preserve">
    <value>{0} shared "{1}" with you on Lilia</value>
  </data>
  <data name="InvitePlainText" xml:space="preserve">
    <value>{0} shared the document "{1}" with you as {2}. Open it at: {3}</value>
  </data>
  <data name="InviteBody" xml:space="preserve">
    <value>{0} has shared a document with you:</value>
  </data>
  <data name="InviteRole" xml:space="preserve">
    <value>Role:</value>
  </data>
  <data name="InviteButton" xml:space="preserve">
    <value>Open Document</value>
  </data>
  <data name="InviteFooter" xml:space="preserve">
    <value>You received this email because someone shared a Lilia document with you.</value>
  </data>
</root>
